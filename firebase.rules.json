{
  "rules": {
    "quiz_sessions": {
      // Lecture : seulement les admins authentifiés
      ".read": "auth != null",
      // Écriture : tout le monde peut créer une entrée (les visiteurs)
      ".write": true,
      "$sessionId": {
        // Validation du schéma des données
        ".validate": "newData.hasChildren(['session_id', 'timestamp', 'profile_dominant', 'score_pct'])",
        "session_id":        { ".validate": "newData.isString() && newData.val().length < 100" },
        "timestamp":         { ".validate": "newData.isString()" },
        "profile_dominant":  { ".validate": "newData.isString() && newData.val().matches(/^(elec|net|cyber|gen)$/)" },
        "score_pct":         { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
        "score_gained":      { ".validate": "newData.isNumber()" },
        "score_possible":    { ".validate": "newData.isNumber()" },
        "nb_questions":      { ".validate": "newData.isNumber()" },
        "scores_by_pole": {
          ".validate": "newData.hasChildren(['elec','net','cyber','gen'])"
        },
        "answers_summary": {
          "$idx": {
            "q":       { ".validate": "newData.isNumber()" },
            "correct": { ".validate": "newData.isBoolean()" },
            "pole":    { ".validate": "newData.isString()" }
          }
        },
        // Interdire tout autre champ (protection contre l'injection de données)
        "$other": { ".validate": false }
      }
    }
  }
}
